{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alchemy-dev-agent.local/specs/repair_plan_schema.json",
  "title": "Alchemy Dev Agent Repair Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repair_plan_id",
    "project_id",
    "source_run_id",
    "trigger",
    "status",
    "summary",
    "repair_signature",
    "items",
    "guardrails",
    "auto_execution",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "repair_plan_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "source_run_id": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "string",
      "enum": [
        "central_review_iterate",
        "delivery_gate_failed",
        "feedback_reopen",
        "manual_operator"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "blocked", "started", "superseded"]
    },
    "summary": {
      "type": "string"
    },
    "repair_signature": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repair_item"
      }
    },
    "guardrails": {
      "$ref": "#/$defs/guardrails"
    },
    "auto_execution": {
      "$ref": "#/$defs/auto_execution"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "repair_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "priority",
        "source",
        "summary",
        "target_agent",
        "target_files",
        "required_evidence",
        "acceptance_check"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["must", "should", "could"]
        },
        "source": {
          "type": "string",
          "enum": [
            "hard_blocker",
            "test_failure",
            "browser_probe",
            "scenario_probe",
            "gameplay_probe",
            "requirement_coverage",
            "reviewer_change",
            "central_review_missing_step",
            "score_dimension",
            "github_ci",
            "manual_feedback"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "target_agent": {
          "type": "string",
          "enum": ["architect", "backend", "frontend", "test", "debug", "reviewer"]
        },
        "target_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_check": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safe_to_execute",
        "max_iterations",
        "current_iteration",
        "duplicate_signature_count",
        "requires_user_approval",
        "blockers"
      ],
      "properties": {
        "safe_to_execute": {
          "type": "boolean"
        },
        "max_iterations": {
          "type": "integer",
          "minimum": 0
        },
        "current_iteration": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_signature_count": {
          "type": "integer",
          "minimum": 0
        },
        "requires_user_approval": {
          "type": "boolean"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "auto_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "mode"],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": ["none", "feedback_reopen"]
        }
      }
    }
  }
}
