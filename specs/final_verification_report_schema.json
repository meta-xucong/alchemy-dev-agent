{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Final Verification Report",
  "type": "object",
  "required": [
    "status",
    "ready_for_final_handoff",
    "audit_status",
    "test_status",
    "dimensions",
    "test_stages",
    "blockers",
    "required_actions",
    "warnings"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["passed", "iterate", "blocked"]
    },
    "ready_for_final_handoff": {
      "type": "boolean"
    },
    "audit_status": {
      "type": "string",
      "enum": ["passed", "iterate", "blocked"]
    },
    "test_status": {
      "type": "string",
      "enum": ["passed", "iterate", "blocked"]
    },
    "dimensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "test_stages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_actions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "worker_verification": {
      "type": "object"
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["id", "question", "status", "summary", "evidence", "required_action"],
      "properties": {
        "id": {"type": "string"},
        "question": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["passed", "warning", "failed"]
        },
        "summary": {"type": "string"},
        "evidence": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_action": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
