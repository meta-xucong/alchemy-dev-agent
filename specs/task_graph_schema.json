{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/alchemy-dev-agent/specs/task_graph_schema.json",
  "title": "Alchemy Dev Agent Task Graph Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["graph_id", "version", "nodes", "dependencies"],
  "properties": {
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "objective_ref": {
      "type": "string",
      "description": "Optional reference to the objective or parent run."
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "type",
        "assigned_agent",
        "status",
        "dependencies",
        "completion_criteria",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "architecture",
            "backend",
            "frontend",
            "test",
            "debug",
            "review",
            "documentation",
            "integration",
            "release"
          ]
        },
        "assigned_agent": {
          "type": "string",
          "enum": ["architect", "backend", "frontend", "test", "debug", "reviewer"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "ready", "active", "blocked", "completed", "failed", "skipped"]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of upstream node IDs required before this node can execute."
        },
        "completion_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Runtime retry count for this task node. Mirrors retry_policy.attempts in persisted runtime state."
        },
        "retry_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 0
            },
            "attempts": {
              "type": "integer",
              "minimum": 0
            },
            "requires_debug_after_failure": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "relevant_files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Repository files or directories the worker should inspect for this task."
        },
        "commands_to_run": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Verification commands the worker should run for this task."
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "branch": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 50
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "type"],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["blocks", "requires_artifact", "requires_review", "requires_test_pass"]
        },
        "artifact_name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "summary"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["worker_result", "test_result", "ci_result", "review", "artifact", "manual_check"]
        },
        "summary": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "location"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["file", "branch", "commit", "pull_request", "test_report", "design_doc", "other"]
        },
        "location": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
